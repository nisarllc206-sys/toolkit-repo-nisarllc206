/* ─── QR Code Generator (Pure Canvas) ─────────────────────────────────────── */
function generateQRMatrix(text) {
  // Simple QR-like visual pattern using text hash for demo
  const size = 21;
  const matrix = Array.from({ length: size }, () => Array(size).fill(0));
  // Finder patterns
  const setFinder = (r, c) => {
    for (let i = 0; i < 7; i++) for (let j = 0; j < 7; j++) {
      if (i === 0 || i === 6 || j === 0 || j === 6 || (i >= 2 && i <= 4 && j >= 2 && j <= 4))
        matrix[r + i][c + j] = 1;
    }
  };
  setFinder(0, 0); setFinder(0, 14); setFinder(14, 0);
  // Data modules from text hash
  let hash = 0;
  for (let i = 0; i < text.length; i++) hash = (hash * 31 + text.charCodeAt(i)) >>> 0;
  for (let i = 8; i < 13; i++) for (let j = 8; j < 13; j++) {
    matrix[i][j] = ((hash >> ((i * 5 + j) % 32)) & 1);
  }
  for (let i = 2; i < 19; i++) for (let j = 2; j < 19; j++) {
    if (matrix[i][j] === 0 && Math.random() < 0.4) {
      const bit = ((hash >> ((i * 7 + j * 3) % 32)) & 1);
      if (!(i < 8 && j < 8) && !(i < 8 && j > 13) && !(i > 13 && j < 8))
        matrix[i][j] = bit;
    }
  }
  return matrix;
}

function QRCanvas({ text, size = 200 }) {
  const canvasRef = useRef(null);
  useEffect(() => {
    if (!canvasRef.current || !text) return;
    const canvas = canvasRef.current;
    const ctx = canvas.getContext("2d");
    const matrix = generateQRMatrix(text);
    const cellSize = size / 21;
    ctx.fillStyle = "#0a0a0f";
    ctx.fillRect(0, 0, size, size);
    matrix.forEach((row, i) => row.forEach((cell, j) => {
      if (cell) {
        ctx.fillStyle = "#00f5ff";
        ctx.shadowColor = "#00f5ff";
        ctx.shadowBlur = 4;
        ctx.fillRect(j * cellSize, i * cellSize, cellSize - 0.5, cellSize - 0.5);
      }
    }));
  }, [text, size]);
  return <canvas ref={canvasRef} width={size} height={size} style={{ borderRadius: 8 }} />;
}

