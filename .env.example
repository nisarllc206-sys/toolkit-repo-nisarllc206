# ─── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-opus-4-6
# Cache TTL in milliseconds (default: 1 hour)
CLAUDE_CACHE_TTL=3600000

# ─── OpenAI (existing) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4

# ─── AI Preferences ────────────────────────────────────────────────────────────
# Options: claude | openai | auto
DEFAULT_AI_MODEL=auto
ENABLE_PROMPT_CACHING=true
COST_OPTIMIZATION_MODE=true
# Set to true to run both models in parallel for /compare endpoint
PARALLEL_GENERATION=false

# ─── Cost Thresholds ───────────────────────────────────────────────────────────
MAX_COST_PER_GENERATION=0.50
CACHE_COST_SAVINGS_TARGET=30

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_TOKEN=your_token
PHONE_NUMBER_ID=your_id
VERIFY_TOKEN=nisar_verify
# Direct WhatsApp contact link
WHATSAPP_LINK=https://wa.me/message/3A7MFOQTRE2ZL1
WHATSAPP_PHONE=03408060167

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# ─── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# ─── Auth / Security ───────────────────────────────────────────────────────────
JWT_SECRET=super_long_random_secret_here
JWT_REFRESH_SECRET=another_super_long_secret

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=100
