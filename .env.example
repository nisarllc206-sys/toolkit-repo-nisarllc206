# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
# Access token from Meta for Developers → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_access_token_here

# Phone Number ID from Meta for Developers → WhatsApp → API Setup
PHONE_NUMBER_ID=your_phone_number_id_here

# Verification token you choose when registering the webhook in Meta dashboard
WHATSAPP_VERIFY_TOKEN=nisar_verify

# Business phone number (E.164 without "+")
# Pakistan: 03408060167 → 923408060167
WHATSAPP_BUSINESS_PHONE=923408060167

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string_here

# ─── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_REFRESH_SECRET=replace_with_another_long_random_secret

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT=100
